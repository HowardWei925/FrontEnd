FROM ubuntu:22.04

# 安装基础工具和编译器
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    make \
    python3 \
    python3-pip \
    gdb \
    strace \
    file \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 用户
RUN useradd -m -s /bin/bash sandbox
USER sandbox
WORKDIR /workspace

# 默认执行 bash
CMD ["/bin/bash"]
